{
  "node": "tool.openrouter_chat_model",
  "details": "Attach an OpenRouter model provider to an agent node with curated routing presets and an optional custom model override.",
  "agentOps": {
    "kind": "tool",
    "displayName": "OpenRouter",
    "icon": "mdi-router-wireless",
    "appId": "openrouter",
    "appLabel": "OpenRouter",
    "appDescription": "One provider node that can route across multiple frontier model ecosystems.",
    "appIcon": "mdi-router-wireless",
    "config": {
      "base_url": "https://openrouter.ai/api/v1",
      "model": "openai/gpt-5.2",
      "custom_model": ""
    },
    "fields": [
      {
        "key": "base_url",
        "label": "API base URL",
        "type": "text",
        "placeholder": "https://openrouter.ai/api/v1"
      },
      {
        "key": "model",
        "label": "Model preset",
        "type": "select",
        "options": [
          {
            "value": "openrouter/auto",
            "label": "OpenRouter Auto"
          },
          {
            "value": "openai/gpt-5.2",
            "label": "OpenAI GPT-5.2"
          },
          {
            "value": "anthropic/claude-sonnet-4.5",
            "label": "Claude Sonnet 4.5"
          },
          {
            "value": "google/gemini-2.5-pro",
            "label": "Gemini 2.5 Pro"
          },
          {
            "value": "x-ai/grok-code-fast-1",
            "label": "Grok Code Fast 1"
          }
        ]
      },
      {
        "key": "custom_model",
        "label": "Custom model ID",
        "type": "text",
        "placeholder": "anthropic/claude-sonnet-4.5",
        "help_text": "Optional advanced override. If set, this exact OpenRouter model ID is used instead of the selected preset."
      },
      {
        "key": "secret_name",
        "label": "Secret name",
        "type": "text",
        "placeholder": "OPENROUTER_API_KEY"
      },
      {
        "key": "secret_group_id",
        "label": "Secret group",
        "type": "text",
        "placeholder": "Use workflow secret group",
        "help_text": "Optional. Override the workflow secret group for this node with a scoped secret group ID."
      },
      {
        "key": "temperature",
        "label": "Temperature",
        "type": "text",
        "placeholder": "0.2"
      },
      {
        "key": "max_tokens",
        "label": "Max tokens",
        "type": "text",
        "placeholder": "800"
      },
      {
        "key": "extra_body_json",
        "label": "Extra body JSON",
        "type": "textarea",
        "rows": 5,
        "placeholder": "{\"response_format\": {\"type\": \"json_object\"}}",
        "help_text": "Optional provider-specific fields merged into the request body after prompts and model."
      }
    ]
  }
}
