{
  "node": "tool.mistral_chat_model",
  "details": "Attach a Mistral model provider to an agent node with curated flagship, coding, and efficient presets plus an optional custom override.",
  "agentOps": {
    "kind": "tool",
    "displayName": "Mistral",
    "icon": "mdi-weather-windy",
    "appId": "mistral",
    "appLabel": "Mistral",
    "appDescription": "Flagship, coding, and efficient frontier models served through Mistral's chat API.",
    "appIcon": "mdi-weather-windy",
    "config": {
      "api_key_name": "MISTRAL_API_KEY",
      "base_url": "https://api.mistral.ai/v1",
      "model": "mistral-large-latest",
      "custom_model": "",
      "auth_secret_group_id": ""
    },
    "fields": [
      {
        "key": "auth_secret_group_id",
        "label": "Auth secret group",
        "type": "select",
        "help_text": "Optional. If set, this node resolves authentication secrets from the selected secret group by assignment key or grouped secret name."
      },
      {
        "key": "base_url",
        "label": "API base URL",
        "type": "text",
        "placeholder": "https://api.mistral.ai/v1"
      },
      {
        "key": "api_key_name",
        "label": "API key secret name",
        "type": "text",
        "placeholder": "MISTRAL_API_KEY"
      },
      {
        "key": "api_key_provider",
        "label": "API key provider",
        "type": "text",
        "placeholder": "environment-variable",
        "help_text": "Optional. Leave blank to search all enabled providers in scope."
      },
      {
        "key": "model",
        "label": "Model preset",
        "type": "select",
        "options": [
          {"value": "mistral-large-latest", "label": "Mistral Large"},
          {"value": "devstral-latest", "label": "Devstral"},
          {"value": "codestral-latest", "label": "Codestral"},
          {"value": "ministral-8b-latest", "label": "Ministral 8B"}
        ]
      },
      {
        "key": "custom_model",
        "label": "Custom model ID",
        "type": "text",
        "placeholder": "mistral-large-latest",
        "help_text": "Optional advanced override. If set, this exact model ID is used instead of the selected preset."
      },
      {
        "key": "temperature",
        "label": "Temperature",
        "type": "text",
        "placeholder": "0.2"
      },
      {
        "key": "max_tokens",
        "label": "Max tokens",
        "type": "text",
        "placeholder": "800"
      },
      {
        "key": "extra_body_json",
        "label": "Extra body JSON",
        "type": "textarea",
        "rows": 5,
        "placeholder": "{\"response_format\": {\"type\": \"json_object\"}}",
        "help_text": "Optional provider-specific fields merged into the request body after prompts and model."
      }
    ]
  }
}
