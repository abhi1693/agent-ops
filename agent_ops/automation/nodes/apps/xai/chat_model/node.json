{
  "node": "tool.xai_chat_model",
  "details": "Attach an xAI model provider to an agent node with curated Grok presets and an optional custom model override.",
  "agentOps": {
    "kind": "tool",
    "displayName": "xAI",
    "icon": "mdi-alpha-x-circle-outline",
    "appId": "xai",
    "appLabel": "xAI",
    "appDescription": "Grok reasoning and coding models exposed through xAI's OpenAI-compatible API.",
    "appIcon": "mdi-alpha-x-circle-outline",
    "config": {
      "api_key_name": "XAI_API_KEY",
      "base_url": "https://api.x.ai/v1",
      "model": "grok-code-fast-1",
      "custom_model": "",
      "auth_secret_group_id": ""
    },
    "fields": [
      {
        "key": "auth_secret_group_id",
        "label": "Auth secret group",
        "type": "select",
        "help_text": "Optional. If set, this node resolves authentication secrets from the selected secret group by assignment key or grouped secret name."
      },
      {
        "key": "base_url",
        "label": "API base URL",
        "type": "text",
        "placeholder": "https://api.x.ai/v1"
      },
      {
        "key": "api_key_name",
        "label": "API key secret name",
        "type": "text",
        "placeholder": "XAI_API_KEY"
      },
      {
        "key": "api_key_provider",
        "label": "API key provider",
        "type": "text",
        "placeholder": "environment-variable",
        "help_text": "Optional. Leave blank to search all enabled providers in scope."
      },
      {
        "key": "model",
        "label": "Model preset",
        "type": "select",
        "options": [
          {"value": "grok-code-fast-1", "label": "Grok Code Fast 1"},
          {"value": "grok-4", "label": "Grok 4"},
          {"value": "grok-3", "label": "Grok 3"},
          {"value": "grok-3-mini", "label": "Grok 3 Mini"}
        ]
      },
      {
        "key": "custom_model",
        "label": "Custom model ID",
        "type": "text",
        "placeholder": "grok-code-fast-1",
        "help_text": "Optional advanced override. If set, this exact model ID is used instead of the selected preset."
      },
      {
        "key": "temperature",
        "label": "Temperature",
        "type": "text",
        "placeholder": "0.2"
      },
      {
        "key": "max_tokens",
        "label": "Max tokens",
        "type": "text",
        "placeholder": "800"
      },
      {
        "key": "extra_body_json",
        "label": "Extra body JSON",
        "type": "textarea",
        "rows": 5,
        "placeholder": "{\"response_format\": {\"type\": \"json_object\"}}",
        "help_text": "Optional provider-specific fields merged into the request body after prompts and model."
      }
    ]
  }
}
