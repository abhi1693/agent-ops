{
  "node": "tool.observability",
  "details": "Observability action node for Prometheus and Elasticsearch operations.",
  "agentOps": {
    "kind": "tool",
    "displayName": "Observability",
    "icon": "mdi-chart-areaspline",
    "appId": "observability",
    "appLabel": "Observability",
    "appDescription": "Ingest alerts and query monitoring systems such as Prometheus and Elasticsearch.",
    "appIcon": "mdi-chart-areaspline",
    "config": {
      "resource": "prometheus",
      "operation": "query",
      "output_key": "observability.result",
      "auth_secret_group_id": ""
    },
    "fields": [
      {
        "key": "auth_secret_group_id",
        "label": "Auth secret group",
        "type": "select",
        "help_text": "Optional. If set, this node resolves authentication secrets from the selected secret group by assignment key or grouped secret name."
      },
      {
        "key": "resource",
        "label": "Resource",
        "type": "select",
        "options": [
          {
            "value": "prometheus",
            "label": "Prometheus"
          },
          {
            "value": "elasticsearch",
            "label": "Elasticsearch"
          }
        ]
      },
      {
        "key": "operation",
        "label": "Operation",
        "type": "select",
        "options": [
          {
            "value": "query",
            "label": "Query"
          },
          {
            "value": "search",
            "label": "Search"
          }
        ],
        "options_by_field": {
          "resource": {
            "prometheus": [
              {
                "value": "query",
                "label": "Query"
              }
            ],
            "elasticsearch": [
              {
                "value": "search",
                "label": "Search"
              }
            ]
          }
        }
      },
      {
        "key": "output_key",
        "label": "Save result as",
        "type": "text",
        "placeholder": "observability.result"
      },
      {
        "key": "base_url",
        "label": "Service base URL",
        "type": "text",
        "placeholder": "https://prometheus.example.com"
      },
      {
        "key": "bearer_token_name",
        "label": "Bearer token secret name",
        "type": "text",
        "placeholder": "PROMETHEUS_API_TOKEN",
        "help_text": "Optional. Leave blank if Prometheus is reachable without auth.",
        "visible_when": {
          "resource": [
            "prometheus"
          ]
        }
      },
      {
        "key": "bearer_token_provider",
        "label": "Bearer token provider",
        "type": "text",
        "placeholder": "environment-variable",
        "help_text": "Optional. Leave blank to search all enabled providers in scope.",
        "visible_when": {
          "resource": [
            "prometheus"
          ]
        }
      },
      {
        "key": "query",
        "label": "PromQL query",
        "type": "textarea",
        "rows": 4,
        "placeholder": "sum(rate(http_requests_total[5m]))",
        "visible_when": {
          "resource": [
            "prometheus"
          ]
        }
      },
      {
        "key": "time",
        "label": "Query time",
        "type": "text",
        "placeholder": "Optional RFC3339 or unix timestamp",
        "visible_when": {
          "resource": [
            "prometheus"
          ]
        }
      },
      {
        "key": "index",
        "label": "Index",
        "type": "text",
        "placeholder": "logs-*",
        "help_text": "Optional. Leave blank to search all indices reachable at this endpoint.",
        "visible_when": {
          "resource": [
            "elasticsearch"
          ]
        }
      },
      {
        "key": "auth_token_name",
        "label": "Auth token secret name",
        "type": "text",
        "placeholder": "ELASTICSEARCH_API_KEY",
        "help_text": "Optional. Provide a token when the cluster requires auth.",
        "visible_when": {
          "resource": [
            "elasticsearch"
          ]
        }
      },
      {
        "key": "auth_token_provider",
        "label": "Auth token provider",
        "type": "text",
        "placeholder": "environment-variable",
        "help_text": "Optional. Leave blank to search all enabled providers in scope.",
        "visible_when": {
          "resource": [
            "elasticsearch"
          ]
        }
      },
      {
        "key": "auth_scheme",
        "label": "Auth scheme",
        "type": "select",
        "options": [
          {
            "value": "ApiKey",
            "label": "ApiKey"
          },
          {
            "value": "Bearer",
            "label": "Bearer"
          }
        ],
        "visible_when": {
          "resource": [
            "elasticsearch"
          ]
        }
      },
      {
        "key": "query_json",
        "label": "Query JSON",
        "type": "textarea",
        "rows": 8,
        "placeholder": "{\"size\": 10, \"query\": {\"match\": {\"service\": \"api\"}}}",
        "visible_when": {
          "resource": [
            "elasticsearch"
          ]
        }
      }
    ],
    "routes": [
      {
        "resource": "prometheus",
        "operation": "query",
        "toolName": "prometheus_query"
      },
      {
        "resource": "elasticsearch",
        "operation": "search",
        "toolName": "elasticsearch_search"
      }
    ]
  }
}
