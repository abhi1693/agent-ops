{
  "node": "tool.prometheus_query",
  "details": "Prometheus query node for observability workflows.",
  "agentOps": {
    "kind": "tool",
    "displayName": "Prometheus query",
    "icon": "mdi-chart-areaspline",
    "appId": "observability",
    "appLabel": "Observability",
    "appDescription": "Ingest alerts and query monitoring systems such as Prometheus and Elasticsearch.",
    "appIcon": "mdi-chart-areaspline",
    "config": {
      "output_key": "prometheus.query"
    },
    "fields": [
      {
        "key": "output_key",
        "label": "Save result as",
        "type": "text",
        "placeholder": "prometheus.query"
      },
      {
        "key": "base_url",
        "label": "Service base URL",
        "type": "text",
        "placeholder": "https://prometheus.example.com"
      },
      {
        "key": "query",
        "label": "PromQL query",
        "type": "textarea",
        "rows": 4,
        "placeholder": "sum(rate(http_requests_total[5m]))"
      },
      {
        "key": "time",
        "label": "Query time",
        "type": "text",
        "placeholder": "Optional RFC3339 or unix timestamp"
      },
      {
        "key": "secret_name",
        "label": "Secret name",
        "type": "text",
        "placeholder": "PROMETHEUS_API_TOKEN",
        "help_text": "Optional. Resolve this secret and send it as a bearer token."
      },
      {
        "key": "secret_group_id",
        "label": "Secret group",
        "type": "text",
        "placeholder": "Use workflow secret group",
        "help_text": "Optional. Override the workflow secret group for this node with a scoped secret group ID."
      }
    ]
  }
}
