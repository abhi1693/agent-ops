{
  "node": "tool.openai_chat_model",
  "details": "Attach an OpenAI model provider to an agent node with curated GPT presets and an optional custom model override.",
  "agentOps": {
    "kind": "tool",
    "displayName": "OpenAI",
    "icon": "mdi-brain",
    "appId": "openai",
    "appLabel": "OpenAI",
    "appDescription": "General-purpose GPT models for production agents and enterprise workflows.",
    "appIcon": "mdi-brain",
    "config": {
      "base_url": "https://api.openai.com/v1",
      "model": "gpt-4.1-mini",
      "custom_model": ""
    },
    "fields": [
      {
        "key": "base_url",
        "label": "API base URL",
        "type": "text",
        "placeholder": "https://api.openai.com/v1"
      },
      {
        "key": "model",
        "label": "Model preset",
        "type": "select",
        "options": [
          {
            "value": "gpt-4.1-mini",
            "label": "GPT-4.1 Mini"
          },
          {
            "value": "gpt-4.1",
            "label": "GPT-4.1"
          },
          {
            "value": "gpt-4o-mini",
            "label": "GPT-4o Mini"
          },
          {
            "value": "gpt-4o",
            "label": "GPT-4o"
          }
        ]
      },
      {
        "key": "custom_model",
        "label": "Custom model ID",
        "type": "text",
        "placeholder": "gpt-5.2",
        "help_text": "Optional advanced override. If set, this exact model ID is used instead of the selected preset."
      },
      {
        "key": "secret_name",
        "label": "Secret name",
        "type": "text",
        "placeholder": "OPENAI_API_KEY"
      },
      {
        "key": "secret_group_id",
        "label": "Secret group",
        "type": "text",
        "placeholder": "Use workflow secret group",
        "help_text": "Optional. Override the workflow secret group for this node with a scoped secret group ID."
      },
      {
        "key": "temperature",
        "label": "Temperature",
        "type": "text",
        "placeholder": "0.2"
      },
      {
        "key": "max_tokens",
        "label": "Max tokens",
        "type": "text",
        "placeholder": "800"
      },
      {
        "key": "extra_body_json",
        "label": "Extra body JSON",
        "type": "textarea",
        "rows": 5,
        "placeholder": "{\"response_format\": {\"type\": \"json_object\"}}",
        "help_text": "Optional provider-specific fields merged into the request body after prompts and model."
      }
    ]
  }
}
