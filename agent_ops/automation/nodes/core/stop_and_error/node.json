{
  "node": "n8n-nodes-base.stopAndError",
  "nodeVersion": "1.0.0",
  "details": "End the workflow with a failed status, modeled after n8n's Stop and Error node.",
  "categories": ["Core Nodes"],
  "subcategories": {
    "Core Nodes": ["Flow"]
  },
  "resources": {
    "primaryDocumentation": [
      {
        "url": "https://docs.n8n.io/integrations/builtin/core-nodes/n8n-nodes-base.stopanderror/"
      }
    ]
  },
  "agentOps": {
    "kind": "response",
    "displayName": "Stop and Error",
    "icon": "mdi-alert-octagon-outline",
    "config": {
      "error_type": "errorMessage"
    },
    "fields": [
      {
        "key": "error_type",
        "label": "Error type",
        "type": "select",
        "options": [
          {
            "value": "errorMessage",
            "label": "Error Message"
          },
          {
            "value": "errorObject",
            "label": "Error Object"
          }
        ]
      },
      {
        "key": "error_message",
        "label": "Error message",
        "type": "text",
        "placeholder": "An error occurred!",
        "helpText": "Used for Error Message type."
      },
      {
        "key": "error_object",
        "label": "Error object",
        "type": "textarea",
        "rows": 4,
        "placeholder": "{\"code\":\"404\",\"description\":\"The resource could not be fetched\"}",
        "helpText": "Used for Error Object type."
      }
    ]
  }
}
